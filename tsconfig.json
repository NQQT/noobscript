{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "skipLibCheck": true,
    "allowJs": true,
    "experimentalDecorators": true,
    "declaration": true,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./lib",
    "lib": [
      "decorators",
      "dom",
      "es5",
      "scripthost",
      "es2015.collection"
    ],
    "types": [
      "*"
    ]
  },
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/dist/*",
    "**/lib/*"
  ]
}
